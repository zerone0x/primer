{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primer.dev/schema/manifest.v1.json",
  "title": "Primer Knowledge Manifest",
  "description": "Schema for .knowledge/manifest.toml (represented as JSON for validation)",
  "type": "object",
  "required": ["manifest"],
  "additionalProperties": false,
  "properties": {
    "manifest": {
      "type": "object",
      "required": ["version", "project"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "const": "1",
          "description": "Manifest schema version"
        },
        "project": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Project name matching project.yaml"
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last generation"
        },
        "generated_by": {
          "type": "string",
          "description": "Tool or agent that generated this manifest"
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["hash", "type"],
        "additionalProperties": false,
        "properties": {
          "hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of the file contents"
          },
          "type": {
            "type": "string",
            "enum": ["gotcha", "skill", "decision", "constraint", "context", "config"],
            "description": "Knowledge file type"
          },
          "size": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes"
          },
          "updated_at": {
            "type": "string",
            "description": "ISO 8601 timestamp of last update"
          }
        }
      },
      "description": "Map of relative file paths to their metadata"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      },
      "description": "Map of file paths to their dependency file paths"
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "gotchas": {
          "type": "integer",
          "minimum": 0
        },
        "skills": {
          "type": "integer",
          "minimum": 0
        },
        "decisions": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
